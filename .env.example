# Copy this file to .env and set strong, unique values.
# .env is ignored by git.

# Database
DB_NAME=wild_beyond
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=wildbeyond
DB_PASSWORD=change_me_to_a_strong_password

# Runtime profile
SPRING_PROFILES_ACTIVE=dev

# Application secrets
JWT_SECRET=change_me_to_a_long_random_secret

# Seeded admin account (required)
APP_ADMIN_EMAIL=admin@wildbeyond.local
APP_ADMIN_PASSWORD=change_me_to_a_strong_admin_password

# Optional app logging path
LOG_PATH=./app.log
