# ─── Default: auto-detect text files, normalise to LF ───────────────────
* text=auto eol=lf

# ─── Source & config files — always LF ──────────────────────────────────
*.java       text eol=lf
*.xml        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.properties text eol=lf
*.json       text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.md         text eol=lf
*.sql        text eol=lf
*.sh         text eol=lf
*.txt        text eol=lf
mvnw         text eol=lf

# ─── Windows scripts — must stay CRLF ───────────────────────────────────
*.cmd        text eol=crlf
*.bat        text eol=crlf
mvnw.cmd     text eol=crlf

# ─── Binary files — no line-ending conversion ────────────────────────────
*.jar     binary
*.gz      binary
*.class   binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.zip     binary
*.tar     binary
